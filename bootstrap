#!/usr/bin/env bash
set -euo pipefail
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/install/lib/log.sh"

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

log_heading "Installing Sebastian's dotfiles.."

# Cache sudo credentials upfront — some casks need them
sudo true
log_success "Granted"
while true; do sudo -n true 2>/dev/null || true; sleep 30; kill -0 "$$" 2>/dev/null || exit; done &
SUDO_LOOP_PID=$!
trap 'kill "$SUDO_LOOP_PID" 2>/dev/null || true' EXIT

# OS specific setup
case "$(uname -s)" in
  Darwin)
    bash "$REPO_DIR/install/macos/all.sh"
    ;;
  *)
    log_warn "Unsupported OS"
    exit 1
    ;;
esac

# Personal dotfiles
bash "$REPO_DIR/install/dotfiles/all.sh"

log_heading "Finishing Sebastian's dotfiles installation..."
log_success "Done!"

exec zsh -l
