#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo -e "\n==> Installing Sebastian's dotfiles.."

# Cache sudo credentials upfront — some casks need them
sudo echo "✓ Granted"
while true; do sudo -n true 2>/dev/null || true; sleep 30; kill -0 "$$" 2>/dev/null || exit; done &
SUDO_LOOP_PID=$!
trap 'kill "$SUDO_LOOP_PID" 2>/dev/null || true' EXIT

# OS specific setup
case "$(uname -s)" in
  Darwin)
    bash "$REPO_DIR/install/macos/all.sh"
    ;;
  *)
    echo "✗ Unsupported OS"
    exit 1
    ;;
esac

# Personal dotfiles
bash "$REPO_DIR/install/dotfiles/all.sh"

# Tailscale
echo -e "\n==> Checking Tailscale connection..."
if timeout 5 tailscale status &>/dev/null; then
  echo "✓ Tailscale connected"
else
  echo "✗ Tailscale is not connected. Run: tailscale up --ssh"
fi

echo -e "\n==> Finishing Sebastian's dotfiles installation..."
echo "✓ Done!"

exec zsh -l
