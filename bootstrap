#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# OS specific setup
case "$(uname -s)" in
  Darwin)
    bash "$REPO_DIR/install/macos/all.sh"
    ;;
  *)
    echo "Unsupported OS"
    exit 1
    ;;
esac

# Personal dotfiles
bash "$REPO_DIR/install/dotfiles.sh"

# Tailscale
if ! tailscale status &>/dev/null; then
  echo "Tailscale is not connected. Run: tailscale up --ssh"
fi

echo -e "\n==> Finished installing Sebastian's dotfiles!"
# Open the manual-steps guide only on first run (Typora not yet in PATH on re-runs would still work,
# but more importantly we skip the interruption when re-running for updates)
if [[ ! -f "$HOME/.dotfiles-bootstrapped" ]]; then
  touch "$HOME/.dotfiles-bootstrapped"
  echo -e "\n==> Manual steps required — opening guide..."
  open -a Typora "$REPO_DIR/docs/macos-omarchy-setup.md"
fi

exec zsh -l
