#!/usr/bin/env bash
set -euo pipefail

REPO="https://github.com/sogamoso/dotfiles.git"
DEST="$HOME/Code/dotfiles"

# Use gum-styled logging when available (re-runs), plain echo on first run
LOG_SH="$DEST/install/lib/log.sh"
[[ -f "$LOG_SH" ]] && source "$LOG_SH"
command -v log_heading &>/dev/null || log_heading() { echo -e "\n==> $1"; }
command -v log_success &>/dev/null || log_success() { echo "✓ $1"; }

if [[ ! -d "$DEST" ]]; then
  log_heading "Cloning dotfiles..."
  mkdir -p "$(dirname "$DEST")"
  git clone --quiet "$REPO" "$DEST"
  log_success "Dotfiles cloned"
else
  log_heading "Updating dotfiles..."
  git -C "$DEST" restore .  # discard stow-caused deletions before pulling
  git -C "$DEST" pull --ff-only --quiet
  log_success "Dotfiles updated"
fi

exec bash "$DEST/bootstrap"
