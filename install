#!/usr/bin/env bash
set -euo pipefail

REPO="https://github.com/sogamoso/dotfiles.git"
DEST="$HOME/Code/dotfiles"

if [[ ! -d "$DEST" ]]; then
  echo "==> Cloning dotfiles..."
  mkdir -p "$(dirname "$DEST")"
  git clone "$REPO" "$DEST"
else
  echo "==> Updating dotfiles..."
  git -C "$DEST" pull --ff-only
fi

exec bash "$DEST/bootstrap"
