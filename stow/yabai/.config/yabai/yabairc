#!/usr/bin/env sh

# Float all windows — don't tile anything
yabai -m config layout float

# Space assignments
# Workspace 1 (Browsing)
yabai -m rule --add app="Google Chrome" space=1
yabai -m rule --add app="Safari" space=1

# Workspace 2 (Programming)
yabai -m rule --add app="Ghostty" space=2
yabai -m rule --add app="Alacritty" space=2
yabai -m rule --add app="Zed" space=2
yabai -m rule --add app="Linear" space=2
yabai -m rule --add app="GitHub" space=2
yabai -m rule --add app="TablePlus" space=2

# Workspace 3 (Communication)
yabai -m rule --add app="Slack" space=3
yabai -m rule --add app="Google Meet" space=3
yabai -m rule --add app="WhatsApp" space=3
yabai -m rule --add app="Discord" space=3

# Workspace 4 (Scheduling)
yabai -m rule --add app="Gmail" space=4
yabai -m rule --add app="Google Calendar" space=4

# Workspace 5 (Writing)
yabai -m rule --add app="Typora" space=5
yabai -m rule --add app="Obsidian" space=5
yabai -m rule --add app="Notion" space=5
yabai -m rule --add app="Notes" space=5

# Workspace 6 (AI Tools)
yabai -m rule --add app="ChatGPT" space=6
yabai -m rule --add app="Claude" space=6
yabai -m rule --add app="Codex" space=6

# Workspace 7 (Entertainment)
yabai -m rule --add app="Spotify" space=7
yabai -m rule --add app="YouTube" space=7
