#!/usr/bin/env bash
# dotfiles — convenience CLI for managing this dotfiles repo.
# Override the repo location via $DOTFILES (default: ~/Code/dotfiles).
set -euo pipefail

DOTFILES="${DOTFILES:-$HOME/Code/dotfiles}"

usage() {
  cat <<EOF
Usage: dotfiles <command>

Commands:
  update          Pull, sync Brewfile, restow, run migrations, reload services
  pull            Git pull only
  brew            Sync Brewfile via brew bundle
  stow            Re-stow all dotfile packages
  reload          Restart SketchyBar and reload AeroSpace
  migrate         Apply pending migrations from migrations/
  migrate-new     Create a new migration stub (\`dotfiles migrate-new "description"\`)
  status          Show repo state (branch, ahead/behind, dirty files)
  edit            Open the repo in \$VISUAL (defaults to nvim)
  help            Show this message
EOF
}

run() { echo "==> $*"; "$@"; }

cmd_pull() {
  run git -C "$DOTFILES" pull --ff-only
}

cmd_brew() {
  run brew bundle install --file="$DOTFILES/Brewfile"
}

cmd_stow() {
  run "$DOTFILES/install/dotfiles/stow.sh"
  if [[ "$(uname -s)" == "Darwin" ]]; then
    run "$DOTFILES/install/macos/dotfiles.sh"
  fi
}

cmd_reload() {
  if command -v sketchybar >/dev/null 2>&1; then
    run sketchybar --reload
  fi
  if command -v aerospace >/dev/null 2>&1; then
    run aerospace reload-config
  fi
}

cmd_migrate() {
  local migrations_dir="$DOTFILES/migrations"
  local state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles"
  local watermark="$state_dir/last-migration"

  [[ -d $migrations_dir ]] || { echo "No migrations directory."; return 0; }

  mkdir -p "$state_dir"
  local last_applied applied=0
  last_applied=$(cat "$watermark" 2>/dev/null || echo 0)

  shopt -s nullglob
  for file in "$migrations_dir"/*.sh; do
    local base ts
    base=$(basename "$file")
    ts="${base%%-*}"
    [[ $ts =~ ^[0-9]+$ ]] || continue
    (( ts <= last_applied )) && continue

    echo "==> Applying migration: $base"
    if ( source "$file" ); then
      echo "$ts" >"$watermark"
      ((applied+=1)) || true
    else
      echo "Migration failed: $base" >&2
      return 1
    fi
  done
  shopt -u nullglob

  if (( applied == 0 )); then
    echo "No new migrations to apply."
  fi
}

cmd_migrate_new() {
  local name="${1:-}"
  [[ -n $name ]] || { echo "Usage: dotfiles migrate-new <description>" >&2; return 64; }

  local ts slug file
  ts=$(date +%s)
  slug=$(echo "$name" | tr '[:upper:]' '[:lower:]' | tr ' _' '-' | tr -cd 'a-z0-9-')
  file="$DOTFILES/migrations/${ts}-${slug}.sh"

  mkdir -p "$DOTFILES/migrations"
  cat >"$file" <<MIGRATION
# Migration: $name
# Created: $(date -u +%Y-%m-%dT%H:%M:%SZ)
#
# This file is sourced (not executed). No shebang. Use \$DOTFILES
# to reference the repo root.

echo "$name"

# Migration code here.
MIGRATION
  chmod 644 "$file"
  echo "Created: $file"
}

cmd_update() {
  cmd_pull
  cmd_brew
  cmd_stow
  cmd_migrate
  cmd_reload
}

cmd_status() {
  cd "$DOTFILES"
  echo "==> Repo: $DOTFILES"
  echo "==> Branch: $(git rev-parse --abbrev-ref HEAD)"
  git fetch --quiet origin 2>/dev/null || true
  local upstream ahead behind
  upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null || echo "")
  if [[ -n $upstream ]]; then
    ahead=$(git rev-list --count "$upstream..HEAD" 2>/dev/null || echo "?")
    behind=$(git rev-list --count "HEAD..$upstream" 2>/dev/null || echo "?")
    echo "==> Vs $upstream: $ahead ahead, $behind behind"
  fi
  echo "==> Working tree:"
  git status --short
}

cmd_edit() {
  ${VISUAL:-nvim} "$DOTFILES"
}

case "${1:-help}" in
  update)         cmd_update ;;
  pull)           cmd_pull ;;
  brew)           cmd_brew ;;
  stow)           cmd_stow ;;
  reload)         cmd_reload ;;
  migrate)        cmd_migrate ;;
  migrate-new)    shift; cmd_migrate_new "${1:-}" ;;
  status)         cmd_status ;;
  edit)           cmd_edit ;;
  help|-h|--help) usage ;;
  *)              echo "Unknown command: $1" >&2; usage >&2; exit 64 ;;
esac
