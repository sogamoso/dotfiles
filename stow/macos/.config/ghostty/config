theme = "tokyonight"
font-family = "JetBrainsMono Nerd Font"
font-size = 12

# Window
window-theme = ghostty
window-padding-x = 14
window-padding-y = 0
confirm-close-surface = false
resize-overlay = never
gtk-toolbar-style = flat

# macOS titlebar
macos-titlebar-style = transparent
macos-window-buttons = hidden
macos-titlebar-proxy-icon = hidden
window-subtitle = false

# Cursor styling
cursor-style = block
cursor-style-blink = false

# Shell integration (no-cursor + ssh-env must be listed together)
shell-integration-features = no-cursor,ssh-env

# Quit when last window closes
quit-after-last-window-closed = true

# Cmd → Meta translation for tmux (physical Command = ALT on Omarchy)
# Sends ESC+key so tmux reads M-1..M-9, M-Left/Right, M-Up/Down
keybind = cmd+digit_1=text:\x1b\x31
keybind = cmd+digit_2=text:\x1b\x32
keybind = cmd+digit_3=text:\x1b\x33
keybind = cmd+digit_4=text:\x1b\x34
keybind = cmd+digit_5=text:\x1b\x35
keybind = cmd+digit_6=text:\x1b\x36
keybind = cmd+digit_7=text:\x1b\x37
keybind = cmd+digit_8=text:\x1b\x38
keybind = cmd+digit_9=text:\x1b\x39
keybind = cmd+left=text:\x1b[1;3D
keybind = cmd+right=text:\x1b[1;3C
keybind = cmd+up=text:\x1b[1;3A
keybind = cmd+down=text:\x1b[1;3B

# New window — Omarchy: Alt+T opens new terminal
keybind = cmd+t=new_window

# Ghostty terminal splits — Omarchy parity
keybind = ctrl+shift+e=new_split:down
keybind = ctrl+shift+o=new_split:right
keybind = ctrl+shift+t=new_tab

# Tab switching — Ctrl+Shift+N (Cmd+N is taken over by tmux)
keybind = ctrl+shift+1=goto_tab:1
keybind = ctrl+shift+2=goto_tab:2
keybind = ctrl+shift+3=goto_tab:3
keybind = ctrl+shift+4=goto_tab:4
keybind = ctrl+shift+5=goto_tab:5
keybind = ctrl+shift+6=goto_tab:6
keybind = ctrl+shift+7=goto_tab:7
keybind = ctrl+shift+8=goto_tab:8
keybind = ctrl+shift+9=goto_tab:9

# Tab navigation
keybind = ctrl+shift+left=previous_tab
keybind = ctrl+shift+right=next_tab

# Tmux pane navigation (Ctrl+Cmd → Ctrl+Meta escape sequences)
keybind = ctrl+cmd+left=text:\x1b[1;7D
keybind = ctrl+cmd+right=text:\x1b[1;7C
keybind = ctrl+cmd+up=text:\x1b[1;7A
keybind = ctrl+cmd+down=text:\x1b[1;7B

# Tmux pane resize (Ctrl+Cmd+Shift → Ctrl+Meta+Shift escape sequences)
keybind = ctrl+cmd+shift+left=text:\x1b[1;8D
keybind = ctrl+cmd+shift+right=text:\x1b[1;8C
keybind = ctrl+cmd+shift+up=text:\x1b[1;8A
keybind = ctrl+cmd+shift+down=text:\x1b[1;8B
