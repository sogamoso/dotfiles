#!/usr/bin/env bash

# Tokyo Night colors
BG=0xff1a1b26
SURFACE=0xff24283b
MUTED=0xff565f89
TEXT=0xffa9b1d6
BLUE=0xff7aa2f7

export CONFIG_DIR="$HOME/.config/sketchybar"

# Compile menu bar height helper if needed
MBHEIGHT_BIN="$CONFIG_DIR/plugins/menu_bar_height"
MBHEIGHT_SRC="$CONFIG_DIR/plugins/menu_bar_height.swift"
if [ ! -f "$MBHEIGHT_BIN" ] || [ "$MBHEIGHT_SRC" -nt "$MBHEIGHT_BIN" ]; then
  swiftc "$MBHEIGHT_SRC" -o "$MBHEIGHT_BIN" 2>/dev/null
fi
BAR_HEIGHT=$("$MBHEIGHT_BIN" 2>/dev/null || echo 30)

# Keep Rectangle Pro's top gap in sync with the bar height.
# Rectangle's gap is global, so use 0 only when the built-in display is the
# only active screen (macOS already reserves top space there). If any external
# display is active (including clamshell with a single external), reserve the
# full bar height to prevent maximized windows from covering SketchyBar.
HAS_EXTERNAL=$(swift -e 'import AppKit; import CoreGraphics; let hasExternal = NSScreen.screens.contains { screen in guard let num = screen.deviceDescription[NSDeviceDescriptionKey("NSScreenNumber")] as? NSNumber else { return false }; return CGDisplayIsBuiltin(num.uint32Value) == 0 }; print(hasExternal ? 1 : 0)' 2>/dev/null || echo 0)
if [ "$HAS_EXTERNAL" -eq 1 ] 2>/dev/null; then
  RECT_GAP=$BAR_HEIGHT
else
  RECT_GAP=0
fi
defaults write com.knollsoft.Hookshot screenEdgeGapTop -int "$RECT_GAP"
defaults write com.knollsoft.Rectangle screenEdgeGapTop -int "$RECT_GAP"
defaults write com.knollsoft.Hookshot applyGapsToMaximize -bool true
defaults write com.knollsoft.Rectangle applyGapsToMaximize -bool true
defaults write com.knollsoft.Hookshot applyGapsToMaximizeHeight -bool true
defaults write com.knollsoft.Rectangle applyGapsToMaximizeHeight -bool true
defaults write com.knollsoft.Hookshot applyGapsToMaximizeWidth -bool true
defaults write com.knollsoft.Rectangle applyGapsToMaximizeWidth -bool true
defaults write com.knollsoft.Hookshot screenEdgeGapsOnMainScreenOnly -bool false
defaults write com.knollsoft.Rectangle screenEdgeGapsOnMainScreenOnly -bool false
killall "Rectangle Pro" 2>/dev/null; open -a "Rectangle Pro" >/dev/null 2>&1 &

# Bar
sketchybar --bar \
  height=$BAR_HEIGHT \
  position=top \
  topmost=off \
  padding_left=12 \
  padding_right=12 \
  color=$BG \
  border_width=0

# Defaults
sketchybar --default \
  padding_left=4 \
  padding_right=4 \
  icon.font="JetBrainsMono Nerd Font:Bold:13.0" \
  label.font="JetBrainsMono Nerd Font:Regular:13.0" \
  icon.color=$TEXT \
  label.color=$TEXT

# Custom events
sketchybar --add event aerospace_workspace_change

# Spaces
for i in {1..9}; do
  sketchybar --add item space.$i left \
    --set space.$i \
      icon=$i \
      icon.padding_left=8 \
      icon.padding_right=8 \
      background.color=$SURFACE \
      background.corner_radius=5 \
      background.height=24 \
      background.drawing=off \
      label.drawing=off \
      click_script="aerospace workspace $i && sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE=$i" \
      script="$CONFIG_DIR/plugins/space.sh" \
    --subscribe space.$i aerospace_workspace_change
done

# Clock (centered)
sketchybar --add item clock center \
  --set clock \
    update_freq=10 \
    icon.drawing=off \
    click_script="open -a Calendar" \
    script="$CONFIG_DIR/plugins/clock.sh"

# Battery
sketchybar --add item battery right \
  --set battery \
    update_freq=120 \
    click_script="open 'x-apple.systempreferences:com.apple.preference.battery'" \
    script="$CONFIG_DIR/plugins/battery.sh" \
  --subscribe battery power_source_change system_woke

# CPU
sketchybar --add item cpu right \
  --set cpu \
    update_freq=5 \
    click_script="$CONFIG_DIR/plugins/cpu_click.sh" \
    script="$CONFIG_DIR/plugins/cpu.sh"

# Memory
sketchybar --add item memory right \
  --set memory \
    update_freq=5 \
    click_script="$CONFIG_DIR/plugins/memory_click.sh" \
    script="$CONFIG_DIR/plugins/memory.sh"

# Volume
sketchybar --add item volume right \
  --set volume \
    update_freq=5 \
    script="$CONFIG_DIR/plugins/volume.sh" \
  --subscribe volume volume_change

# Bluetooth
sketchybar --add item bluetooth right \
  --set bluetooth \
    update_freq=10 \
    label.drawing=off \
    click_script="open 'x-apple.systempreferences:com.apple.preferences.Bluetooth'" \
    script="$CONFIG_DIR/plugins/bluetooth.sh"

# WiFi
sketchybar --add item wifi right \
  --set wifi \
    update_freq=30 \
    click_script="open 'x-apple.systempreferences:com.apple.preference.network'" \
    script="$CONFIG_DIR/plugins/wifi.sh" \
  --subscribe wifi wifi_change

sketchybar --update
