#!/usr/bin/env bash

# Tokyo Night colors
BG=0xff1a1b26
SURFACE=0xff24283b
MUTED=0xff565f89
TEXT=0xffa9b1d6
BLUE=0xff7aa2f7

export CONFIG_DIR="$HOME/.config/sketchybar"

# Compile menu bar height helper if needed (build to ~/.cache to avoid stow conflicts)
CACHE_DIR="$HOME/.cache/sketchybar"
mkdir -p "$CACHE_DIR"
MBHEIGHT_BIN="$CACHE_DIR/menu_bar_height"
MBHEIGHT_SRC="$CONFIG_DIR/plugins/menu_bar_height.swift"
if [ ! -f "$MBHEIGHT_BIN" ] || [ "$MBHEIGHT_SRC" -nt "$MBHEIGHT_BIN" ]; then
  swiftc "$MBHEIGHT_SRC" -o "$MBHEIGHT_BIN" 2>/dev/null
fi
BAR_HEIGHT=$("$MBHEIGHT_BIN" 2>/dev/null || echo 30)

# Sync AeroSpace outer.top gap with the bar height (no reload — reload() handles that)
"$CONFIG_DIR/plugins/sync_aerospace_gap.sh"

# Bar
sketchybar --bar \
  height=$BAR_HEIGHT \
  position=top \
  topmost=off \
  padding_left=12 \
  padding_right=12 \
  color=$BG \
  border_width=0

# Defaults
sketchybar --default \
  padding_left=4 \
  padding_right=4 \
  icon.font="JetBrainsMono Nerd Font:Bold:16.0" \
  label.font="JetBrainsMono Nerd Font:Regular:13.0" \
  icon.color=$TEXT \
  label.color=$TEXT

# Custom events
sketchybar --add event aerospace_workspace_change

# Apple workspace menu — leftmost item
sketchybar --add item apple_menu left \
  --set apple_menu \
    icon="⌘" \
    icon.font="JetBrainsMono Nerd Font:Bold:16.0" \
    label.drawing=off \
    padding_left=8 \
    padding_right=4 \
    popup.align=left \
    popup.background.color=$SURFACE \
    popup.background.corner_radius=6 \
    popup.background.border_width=1 \
    popup.background.border_color=$MUTED \
    click_script="$CONFIG_DIR/plugins/workspace_menu.sh" \
    script="$CONFIG_DIR/plugins/workspace_menu_close.sh" \
  --subscribe apple_menu front_app_switched mouse.exited.global

for i in {1..9}; do
  sketchybar --add item apple_menu.ws.$i popup.apple_menu \
    --set apple_menu.ws.$i \
      label="$i" \
      label.font="JetBrainsMono Nerd Font:Regular:13.0" \
      padding_left=8 \
      padding_right=12 \
      width=280 \
      background.color=$BLUE \
      background.corner_radius=4 \
      background.height=22 \
      background.drawing=off \
      click_script="rm -f /tmp/sketchybar_menu_keyboard; sketchybar --set apple_menu.ws.$i background.drawing=off; sketchybar --set apple_menu popup.drawing=off; aerospace workspace $i; sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE=$i"
done

# Spaces (1:Ghostty/Zed, 2:Chrome/Safari/Meet, 3:Slack, 4:Gmail,
# 5:Calendar, 6:Todoist/Notion/Linear, 7:HEY, 8:WhatsApp, 9:Spotify/YouTube)
# Workspace 10 is the scratchpad, no indicator needed.
for i in {1..9}; do
  sketchybar --add item space.$i left \
    --set space.$i \
      icon=$i \
      icon.font="JetBrainsMono Nerd Font:Bold:13.0" \
      icon.padding_left=8 \
      icon.padding_right=8 \
      background.color=$SURFACE \
      background.corner_radius=5 \
      background.height=24 \
      background.drawing=off \
      label.drawing=off \
      click_script="aerospace workspace $i && sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE=$i" \
      script="$CONFIG_DIR/plugins/space.sh" \
    --subscribe space.$i aerospace_workspace_change
done

# Clock — right on laptop (single display), centered on external
HAS_EXTERNAL=$(cat /tmp/sketchybar_has_external 2>/dev/null || echo 0)
[ "$HAS_EXTERNAL" -eq 1 ] && CLOCK_POS=center || CLOCK_POS=right
echo "$CLOCK_POS" > /tmp/sketchybar_clock_pos

sketchybar --add item clock $CLOCK_POS \
  --set clock \
    update_freq=5 \
    icon.drawing=off \
    click_script="$CONFIG_DIR/plugins/clock_alt.sh" \
    script="$CONFIG_DIR/plugins/clock.sh"

# Battery (NOTE: system_woke event may not fire on all macOS versions)
sketchybar --add item battery right \
  --set battery \
    update_freq=120 \
    click_script="open 'x-apple.systempreferences:com.apple.preference.battery'" \
    script="$CONFIG_DIR/plugins/battery.sh" \
  --subscribe battery power_source_change

# CPU
sketchybar --add item cpu right \
  --set cpu \
    icon.font="JetBrainsMono Nerd Font:Bold:19.0" \
    update_freq=5 \
    click_script="$CONFIG_DIR/plugins/activity_monitor.sh" \
    script="$CONFIG_DIR/plugins/cpu.sh"

# Memory
sketchybar --add item memory right \
  --set memory \
    icon.font="JetBrainsMono Nerd Font:Bold:19.0" \
    update_freq=5 \
    click_script="$CONFIG_DIR/plugins/activity_monitor.sh" \
    script="$CONFIG_DIR/plugins/memory.sh"

# Volume
sketchybar --add item volume right \
  --set volume \
    icon.font="JetBrainsMono Nerd Font:Bold:21.0" \
    update_freq=5 \
    click_script="osascript -e 'set volume output muted not (output muted of (get volume settings))'" \
    script="$CONFIG_DIR/plugins/volume.sh" \
  --subscribe volume volume_change

# Bluetooth
sketchybar --add item bluetooth right \
  --set bluetooth \
    icon.font="JetBrainsMono Nerd Font:Bold:17.0" \
    update_freq=10 \
    label.drawing=off \
    click_script="open 'x-apple.systempreferences:com.apple.preferences.Bluetooth'" \
    script="$CONFIG_DIR/plugins/bluetooth.sh"

# WiFi (NOTE: wifi_change event is fragile - removed)
sketchybar --add item wifi right \
  --set wifi \
    update_freq=30 \
    click_script="open 'x-apple.systempreferences:com.apple.wifi-settings-extension'" \
    script="$CONFIG_DIR/plugins/wifi.sh"

# Input source
sketchybar --add item input_source right \
  --set input_source \
    icon.drawing=off \
    label.font="JetBrainsMono Nerd Font:Bold:10.0" \
    label.color=0xff1a1b26 \
    label.padding_left=4 \
    label.padding_right=4 \
    background.color=$MUTED \
    background.corner_radius=3 \
    background.height=15 \
    background.drawing=on \
    padding_left=4 \
    padding_right=4 \
    update_freq=3 \
    click_script="BIN=$HOME/.cache/sketchybar/switch_input_source; SRC=$CONFIG_DIR/plugins/switch_input_source.swift; [ ! -f \$BIN ] || [ \$SRC -nt \$BIN ] && swiftc \$SRC -framework Carbon -o \$BIN 2>/dev/null; \$BIN" \
    script="$CONFIG_DIR/plugins/input_source.sh"

# Calendar
sketchybar --add item calendar right \
  --set calendar \
    icon="󰃭" \
    label.drawing=off \
    click_script="open -b 'com.google.Chrome.app.kjbdgfilnfhdoflbpgamdcdgpehopbep'"

# Display change watcher — reloads bar when displays are added/removed (NOTE: system_woke may not fire on all macOS)
sketchybar --add item display_watcher left \
  --set display_watcher \
    drawing=off \
    script="$CONFIG_DIR/plugins/display_change.sh" \
  --subscribe display_watcher display_change display_added display_removed

sketchybar --update
