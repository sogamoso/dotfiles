#!/usr/bin/env bash

# Tokyo Night colors
BG=0xff1a1b26
SURFACE=0xff24283b
MUTED=0xff565f89
TEXT=0xffa9b1d6
BLUE=0xff7aa2f7

export CONFIG_DIR="$HOME/.config/sketchybar"

# Bar
sketchybar --bar \
  height=22 \
  position=top \
  topmost=off \
  padding_left=12 \
  padding_right=12 \
  color=$BG \
  border_width=0

# Defaults
sketchybar --default \
  padding_left=4 \
  padding_right=4 \
  icon.font="JetBrainsMono Nerd Font:Bold:13.0" \
  label.font="JetBrainsMono Nerd Font:Regular:13.0" \
  icon.color=$TEXT \
  label.color=$TEXT

# Custom events
sketchybar --add event aerospace_workspace_change

# Spaces
for i in {1..9}; do
  sketchybar --add item space.$i left \
    --set space.$i \
      icon=$i \
      icon.padding_left=8 \
      icon.padding_right=8 \
      background.color=$SURFACE \
      background.corner_radius=5 \
      background.height=24 \
      background.drawing=off \
      label.drawing=off \
      click_script="aerospace workspace $i && sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE=$i" \
      script="$CONFIG_DIR/plugins/space.sh" \
    --subscribe space.$i aerospace_workspace_change
done

# Clock (centered)
sketchybar --add item clock center \
  --set clock \
    update_freq=10 \
    icon.drawing=off \
    click_script="open -a Calendar" \
    script="$CONFIG_DIR/plugins/clock.sh"

# Battery
sketchybar --add item battery right \
  --set battery \
    update_freq=120 \
    click_script="open 'x-apple.systempreferences:com.apple.preference.battery'" \
    script="$CONFIG_DIR/plugins/battery.sh" \
  --subscribe battery power_source_change system_woke

# CPU
sketchybar --add item cpu right \
  --set cpu \
    update_freq=5 \
    click_script="$CONFIG_DIR/plugins/cpu_click.sh" \
    script="$CONFIG_DIR/plugins/cpu.sh"

# Memory
sketchybar --add item memory right \
  --set memory \
    update_freq=5 \
    click_script="$CONFIG_DIR/plugins/memory_click.sh" \
    script="$CONFIG_DIR/plugins/memory.sh"

# Volume
sketchybar --add item volume right \
  --set volume \
    update_freq=5 \
    script="$CONFIG_DIR/plugins/volume.sh" \
  --subscribe volume volume_change

# Bluetooth
sketchybar --add item bluetooth right \
  --set bluetooth \
    update_freq=10 \
    label.drawing=off \
    click_script="open 'x-apple.systempreferences:com.apple.preferences.Bluetooth'" \
    script="$CONFIG_DIR/plugins/bluetooth.sh"

# WiFi
sketchybar --add item wifi right \
  --set wifi \
    update_freq=30 \
    click_script="open 'x-apple.systempreferences:com.apple.preference.network'" \
    script="$CONFIG_DIR/plugins/wifi.sh" \
  --subscribe wifi wifi_change

sketchybar --update
