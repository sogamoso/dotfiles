{
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "agent": {
    "dock": "left",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "right"
  },
  "which_key": {
    "enabled": true
  },
  "ui_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "when_closing_with_no_tabs": "close_window",
  "session": {
    "trust_all_worktrees": true
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false
  },
  "icon_theme": "Zed (Default)",
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "auto_install_extensions": {
    "dockerfile": true,
    "git-firefly": true,
    "html": true,
    "mdx": true,
    "ruby": true,
    "tokyo-night": true,
    "toml": true
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": ["cn", "clsx", "cva"]
      }
    }
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_multiline_find": true
  },
  "relative_line_numbers": true,
  "format_on_save": "on",
  "current_line_highlight": "all",
  "cursor_blink": false,
  "scrollbar": {
    "show": "never"
  },
  "inlay_hints": {
    "enabled": true
  },
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "show_whitespaces": "selection",
  "toolbar": {
    "breadcrumbs": true
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": "Tokyo Night"
}
